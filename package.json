{
  "name": "leh-wi-tok",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "preinstall": "npm run enforce-node-version",
    "enforce-node-version": "node -v | grep -q 'v22.10.0' || (echo 'Explicit node version is required. Expected v22.10.0' && exit 1)",
    "start": "expo start",
    "start:clear": "expo start --clear",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"{app,components,hooks,constants,lib,utils,config,data,db}/**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"{app,components,hooks,constants,lib,utils,config,data,db}/**/*.{js,jsx,ts,tsx,json,md}\"",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --max-warnings 0",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "lint:staged": "lint-staged",
    "validate": "npm run type-check && npm run lint && npm run format:check",
    "security-check": "npm audit --audit-level=moderate",
    "expo-doctor": "npx expo-doctor",
    "pre-push-check": "npm run type-check && npm run lint && npm run security-check && npm run expo-doctor",
    "prepare": "husky"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings 0"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "~14.0.4",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-navigation/native": "^7.0.14",
    "expo": "~52.0.47",
    "expo-constants": "~17.0.4",
    "expo-dev-client": "~5.0.20",
    "expo-file-system": "~18.0.12",
    "expo-font": "~13.0.3",
    "expo-image": "~2.0.7",
    "expo-image-picker": "~16.0.6",
    "expo-linking": "~7.0.5",
    "expo-router": "~4.0.21",
    "expo-splash-screen": "~0.29.24",
    "expo-sqlite": "~15.1.4",
    "expo-status-bar": "~2.0.1",
    "expo-system-ui": "~4.0.9",
    "expo-video": "~2.0.6",
    "expo-web-browser": "~14.0.2",
    "react": "18.3.1",
    "react-dom": "^18.3.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.10",
    "react-native-webview": "^13.12.5"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/jest": "^29.5.12",
    "@types/react": "~18.3.12",
    "@types/react-test-renderer": "^18.0.7",
    "@typescript-eslint/eslint-plugin": "^7.16.1",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^6.1.1",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-unused-imports": "^3.2.0",
    "husky": "^9.1.7",
    "jest": "^29.2.1",
    "jest-expo": "~52.0.6",
    "lint-staged": "^16.2.3",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "typescript": "~5.3.3"
  },
  "private": true
}
